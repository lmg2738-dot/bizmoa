# ===========================================
# 비즈모아 (BizMoa) 환경변수 — 값은 비워두세요
# Vercel / 로컬 .env 에만 실제 값을 설정하세요
# ===========================================

# --- AI (OpenRouter) — 서버 Secret ---
OPENROUTER_API_KEY=""
OPENROUTER_SITE_URL="https://your-app.vercel.app"
OPENROUTER_APP_NAME="BizMoa"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
DATABASE_URL=""

# --- 한국수출입은행 Open API (동일 URL, data 코드만 다름) ---
# AP01=환율, AP02=대출금리, AP03=국제금리
KEXIM_API_BASE_URL="https://oapi.koreaexim.go.kr/site/program/financial/exchangeJSON"
KEXIM_EXCHANGE_API_KEY=""
KEXIM_LOAN_RATE_API_KEY=""
KEXIM_INTL_RATE_API_KEY=""

# --- 금융결제원 / KIS (미연동 시 시뮬레이션 모드) ---
OPENBANKING_CLIENT_ID=""
OPENBANKING_CLIENT_SECRET=""
OPENBANKING_REDIRECT_URI="https://your-app.vercel.app/api/auth/banking/callback"
KIS_APP_KEY=""
KIS_APP_SECRET=""
KIS_IS_MOCK="true"

# --- 기타 ---
ENCRYPTION_KEY=""
REJECT_UNAUTHORIZED="true"
