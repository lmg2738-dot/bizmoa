generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  businessName    String   @map("business_name")
  businessNumber  String   @unique @map("business_number") // 암호화 필요
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  linkedAccounts      LinkedAccount[]
  investmentAccounts  InvestmentAccount[]
  transactions        Transaction[]

  @@map("users")
}

model LinkedAccount {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  bankCode      String   @map("bank_code")
  bankName      String   @map("bank_name")
  accountNumber String   @map("account_number") // 암호화 필요
  accountAlias  String?  @map("account_alias")
  balance       Decimal  @default(0) @db.Decimal(18, 2)
  accessToken   String   @map("access_token") // 암호화 필요
  refreshToken  String   @map("refresh_token") // 암호화 필요
  expiresAt     DateTime @map("expires_at")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, bankCode, accountNumber])
  @@map("linked_accounts")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionSource {
  BANK
  PG
  INVESTMENT
  TRANSFER
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String            @map("user_id")
  accountId       String?           @map("account_id")
  type            TransactionType
  source          TransactionSource @default(BANK)
  amount          Decimal           @db.Decimal(18, 2)
  description     String?
  transactionDate DateTime          @map("transaction_date")
  createdAt       DateTime          @default(now()) @map("created_at")

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  account LinkedAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([userId, transactionDate])
  @@map("transactions")
}

enum InvestmentStatus {
  IDLE
  INVESTED
  PENDING
}

model InvestmentAccount {
  id                   String           @id @default(cuid())
  userId               String           @map("user_id")
  appKey               String           @map("app_key") // 암호화 필요
  appSecret            String           @map("app_secret") // 암호화 필요
  canoeAccountNumber   String           @map("canoe_account_number") // 암호화 필요 (증권 계좌번호)
  currentValue         Decimal          @default(0) @map("current_value") @db.Decimal(18, 2)
  investmentStatus     InvestmentStatus @default(IDLE) @map("investment_status")
  lastInvestedAt       DateTime?        @map("last_invested_at")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("investment_accounts")
}

model PgSettlement {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  pgProvider     String   @map("pg_provider")
  settlementDate DateTime @map("settlement_date")
  amount         Decimal  @db.Decimal(18, 2)
  status         String   @default("PENDING")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([userId, settlementDate])
  @@map("pg_settlements")
}
